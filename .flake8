[flake8]
# Setar o 
max-line-length = 100

# Ignore specific error codes (e.g., E203 for compatibility with Black)
extend-ignore = E203, W503

# Exclude specific directories or files from linting
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    venv
    __init__.py

# Set McCabe complexity threshold
max-complexity = 25

# Disable specific errors for certain files
per-file-ignores =
    __init__.py: F401
    tests/*.py: S101